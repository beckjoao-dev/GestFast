# ═══════════════════════════════════════════════════════════════════
# GESTFAST — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA faça commit do arquivo .env no GitHub.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase (banco de dados) ────────────────────────────────────
# DATABASE_URL: URL com pgBouncer (pooling) — usada pelo app em produção
# Formato: postgresql://postgres.[ref]:[senha]@aws-0-[região].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.SUAREF:SUASENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: URL direta sem pooling — usada só pelo Prisma para migrations
# Formato: postgresql://postgres.[ref]:[senha]@aws-0-[região].pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres.SUAREF:SUASENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ── Segurança JWT ─────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cole-aqui-64-bytes-hexadecimais-gerados-pelo-comando-acima"
JWT_EXPIRES_IN="8h"

# ── Ambiente ──────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
