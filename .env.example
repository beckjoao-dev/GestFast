# ── Banco de dados ────────────────────────────────────────────────────────────
# Railway PostgreSQL URL (produção) ou local (desenvolvimento)
DATABASE_URL="postgresql://user:password@localhost:5432/gestfast"

# ── Segurança JWT ─────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="sua-chave-secreta-de-64-bytes-aqui"
JWT_EXPIRES_IN="8h"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
